---
import ThemeToggle from './ui/ThemeToggle.astro'
import DesktopIcon from './ui/DesktopIcon.astro'
import CherryBlossoms from './features/CherryBlossoms.astro'
import WindowContent from './WindowContent.astro'
import { USER_NAME, CURRENT_YEAR } from '../lib/constants'
import { Image } from 'astro:assets'

const base = import.meta.env.BASE_URL ?? '/'
---

<div class="desktop">
  <CherryBlossoms />
  
  <div class="decorations">
    <div class="sakura-decoration">
      <Image src={`${base}images/sakura.webp`} alt="Sakura decoration" width={400} height={300} />
    </div>
    <div class="lily-decoration hidden">
      <Image src={`${base}images/lily.webp`} alt="Lily decoration" width={300} height={200} class="lily-1" />
      <Image src={`${base}images/lily.webp`} alt="Lily decoration" width={250} height={180} class="lily-2" />
    </div>
  </div>

  <div class="controls">
    <ThemeToggle />
  </div>

  <div class="desktop-content">
    <div class="home-window" id="home-window">
      <div class="home-titlebar" aria-hidden="true">
        <span class="titlebar-dot"></span>
        <span class="titlebar-dot"></span>
        <span class="titlebar-dot"></span>
        <span class="home-titlebar-label">quiet.local</span>
      </div>
      <header class="home-header">
        <span id="greeting" class="greeting" lang="ja">こんにちは！</span>
      </header>
      <div class="icon-grid">
        <DesktopIcon id="about" name="about" />
        <DesktopIcon id="links" name="links" />
        <DesktopIcon id="work" name="work" />
        <DesktopIcon id="faq" name="faq" />
      </div>
    </div>
  </div>

  <p class="konami-hint">Hint: try the Konami code</p>

  <div id="windows-container" class="windows-container"></div>

  <div id="konami-controller" class="konami-controller hidden">
    <div class="controller-shell">
      <div class="controller-header">
        <div class="controller-brand">
          <span class="controller-mark" aria-hidden="true">♡</span>
          <h3>konami pad</h3>
        </div>
        <button id="controller-close" aria-label="Close controller">×</button>
      </div>
      <div class="sequence-progress" aria-label="Konami sequence progress">
        <span class="dot" data-index="0"></span>
        <span class="dot" data-index="1"></span>
        <span class="dot" data-index="2"></span>
        <span class="dot" data-index="3"></span>
        <span class="dot" data-index="4"></span>
        <span class="dot" data-index="5"></span>
        <span class="dot" data-index="6"></span>
        <span class="dot" data-index="7"></span>
        <span class="dot" data-index="8"></span>
        <span class="dot" data-index="9"></span>
      </div>
      <div class="controller-body">
        <jpad-controller>
          <div class="dpad" aria-label="Directional buttons">
            <jpad-button id="btn-up" name="up" keys="ArrowUp" aria-label="Up">↑</jpad-button>
            <jpad-button id="btn-down" name="down" keys="ArrowDown" aria-label="Down">↓</jpad-button>
            <jpad-button id="btn-left" name="left" keys="ArrowLeft" aria-label="Left">←</jpad-button>
            <jpad-button id="btn-right" name="right" keys="ArrowRight" aria-label="Right">→</jpad-button>
          </div>
          <div class="controller-center" aria-hidden="true">
            <span class="speaker-line"></span>
            <span class="speaker-line"></span>
            <span class="speaker-line"></span>
            <span class="start-pill">start</span>
          </div>
          <div class="action-buttons" aria-label="Action buttons">
            <jpad-button id="btn-b" name="b" keys="KeyB" aria-label="B">B</jpad-button>
            <jpad-button id="btn-a" name="a" keys="KeyA" aria-label="A">A</jpad-button>
          </div>
        </jpad-controller>
      </div>
    </div>
  </div>

  <WindowContent />

<script>
  import { $windows, $sortedWindows, $activeWindowId, openWindow, closeWindow } from '../stores/windows'
  import { renderWindow } from '../lib/windowRenderer'
  import 'jpad-components'

  function createWindowEl(state: { id: string; title: string; position: { x: number; y: number }; size: { width: number; height: number }; zIndex: number; isLoading: boolean }): HTMLElement {
    const el = document.createElement('div')
    el.className = 'window'
    el.dataset.windowId = state.id
    el.style.cssText = `left: ${state.position.x}px; top: ${state.position.y}px; width: ${state.size.width}px; height: ${state.size.height}px; z-index: ${state.zIndex};`
    
    el.innerHTML = `
      <header class="window-header" data-drag-handle>
        <div class="window-titlebar-dots">
          <button class="titlebar-dot titlebar-dot-close" data-close aria-label="Close ${state.title}"></button>
          <span class="titlebar-dot titlebar-dot-minimize"></span>
          <span class="titlebar-dot titlebar-dot-maximize"></span>
        </div>
        <span class="window-title">${state.title}</span>
      </header>
      <main class="window-content"></main>
    `
    
    requestAnimationFrame(() => {
      el.classList.add('is-open')
      renderWindow(state.id, el)
    })
    
    return el
  }

  function syncWindows(): void {
    const container = document.getElementById('windows-container')
    if (!container) return

    const windows = $sortedWindows.get()
    const activeId = $activeWindowId.get()
    const existingEls = new Map<string, HTMLElement>()
    
    container.querySelectorAll('.window').forEach(el => {
      const id = (el as HTMLElement).dataset.windowId
      if (id) existingEls.set(id, el as HTMLElement)
    })

    const currentIds = new Set(windows.map(w => w.id))
    
    existingEls.forEach((el, id) => {
      if (!currentIds.has(id)) {
        el.remove()
      }
    })

    windows.forEach(state => {
      let el = existingEls.get(state.id)
      
      if (!el) {
        el = createWindowEl(state)
        container.appendChild(el)
      } else {
        el.style.left = `${state.position.x}px`
        el.style.top = `${state.position.y}px`
        el.style.zIndex = String(state.zIndex)
        el.classList.toggle('is-active', state.id === activeId)
      }
    })
  }

  function initKonamiCode(): void {
    const konamiCode = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'KeyB', 'KeyA']
    let konamiIndex = 0

    function updateSequenceDots(): void {
      const dots = document.querySelectorAll('#konami-controller .dot')
      dots.forEach((dot, i) => {
        if (i < konamiIndex) {
          dot.classList.add('active')
        } else {
          dot.classList.remove('active')
        }
      })
    }

    function triggerAutism(): void {
      document.body.classList.add('konami-activated')
      setTimeout(() => {
        document.body.classList.remove('konami-activated')
      }, 500)
      
      openWindow('autism')
      hideController()
      konamiIndex = 0
      updateSequenceDots()
    }

    function handleKonamiInput(key: string): void {
      const expectedKey = konamiCode[konamiIndex]
      
      if (key === expectedKey) {
        konamiIndex++
        updateSequenceDots()
        
        if (konamiIndex === konamiCode.length) {
          setTimeout(triggerAutism, 300)
        }
      } else {
        konamiIndex = 0
        updateSequenceDots()
      }
    }

    function handleKeyDown(e: KeyboardEvent): void {
      handleKonamiInput(e.code)
    }

    function showController(): void {
      const controller = document.getElementById('konami-controller')
      controller?.classList.remove('hidden')
      konamiIndex = 0
      updateSequenceDots()
    }

    function hideController(): void {
      const controller = document.getElementById('konami-controller')
      controller?.classList.add('hidden')
      konamiIndex = 0
      updateSequenceDots()
    }

    function initControllerButtons(): void {
      const buttons = [
        { id: 'btn-up', key: 'ArrowUp' },
        { id: 'btn-down', key: 'ArrowDown' },
        { id: 'btn-left', key: 'ArrowLeft' },
        { id: 'btn-right', key: 'ArrowRight' },
        { id: 'btn-a', key: 'KeyA' },
        { id: 'btn-b', key: 'KeyB' },
      ]

      buttons.forEach(({ id, key }) => {
        const btn = document.getElementById(id)
        btn?.addEventListener('click', () => handleKonamiInput(key))
      })

      document.getElementById('controller-close')?.addEventListener('click', hideController)
    }

    function setupControllerTrigger(): void {
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'childList') {
            const triggerPanel = document.getElementById('controller-trigger-panel')
            if (triggerPanel && !triggerPanel.hasAttribute('data-initialized')) {
              triggerPanel.addEventListener('click', () => {
                closeWindow('faq')
                setTimeout(showController, 350)
              })
              triggerPanel.setAttribute('data-initialized', 'true')
            }
          }
        })
      })

      observer.observe(document.body, { childList: true, subtree: true })
    }

    document.addEventListener('keydown', handleKeyDown)
    initControllerButtons()
    setupControllerTrigger()
  }

  document.addEventListener('astro:page-load', () => {
    $windows.subscribe(syncWindows)
    $activeWindowId.subscribe(syncWindows)
    initKonamiCode()
    updateGreeting()
  })

  function updateGreeting(): void {
    const greetingEl = document.getElementById('greeting')
    if (!greetingEl) return
    
    const hour = new Date().getHours()
    const isNight = hour >= 18 || hour < 6
    greetingEl.textContent = isNight ? 'こんばんわ！' : 'こんにちは！'
  }
</script>

  <video
    id="lain-bg-video"
    autoplay
    loop
    muted
    playsinline
    class="lain-video hidden"
  >
    <source src={`${base}images/lain.webm`} type="video/webm" />
  </video>

  <footer class="footer">
    <span class="copyright">&copy; {CURRENT_YEAR} {USER_NAME}</span>
  </footer>
</div>

<style>
  .desktop {
    display: flex;
    flex-direction: column;
    height: 100vh;
    position: relative;
    background-color: var(--window-bg);
    isolation: isolate;
  }

  .decorations {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .sakura-decoration {
    position: absolute;
    bottom: 0;
    left: 0;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.9;
    transform-origin: bottom left;
    animation: float 8s ease-in-out infinite;
  }

  .sakura-decoration img {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.3));
  }

  :global(.dark) .sakura-decoration img {
    filter: drop-shadow(0 0 10px rgba(0, 0, 0, 0.3)) brightness(0.9);
  }

  .lily-decoration {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .lily-1 {
    position: absolute;
    bottom: -20px;
    left: -20px;
    width: 300px;
    transform: scale(1.2) rotate(-5deg);
    animation: float 8s ease-in-out infinite;
  }

  .lily-2 {
    position: absolute;
    bottom: -10px;
    left: 120px;
    width: 250px;
    transform: scale(0.9) rotate(8deg);
    animation: float 10s ease-in-out infinite reverse;
    z-index: 2;
  }

  :global(.dark) .lily-1,
  :global(.dark) .lily-2 {
    filter: brightness(0.7) hue-rotate(30deg);
  }

  .controls {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 100;
  }

  .desktop-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 20px;
    z-index: 10;
  }

  .home-window {
    background-color: var(--window-content-bg);
    border: 1px solid var(--window-border);
    border-radius: 18px;
    padding: 2rem;
    box-shadow: var(--window-shadow);
    backdrop-filter: blur(var(--window-blur)) saturate(var(--window-saturate));
    -webkit-backdrop-filter: blur(var(--window-blur)) saturate(var(--window-saturate));
    z-index: 5;
    position: relative;
    overflow: hidden;
  }

  .home-window::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.2);
  }

  .home-titlebar {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin: -2rem -2rem 1.5rem;
    padding: 0.55rem 0.85rem;
    background-color: var(--window-title-bg);
    backdrop-filter: blur(var(--window-blur)) saturate(var(--window-saturate));
    -webkit-backdrop-filter: blur(var(--window-blur)) saturate(var(--window-saturate));
    color: var(--window-title-text);
    font-size: 0.8rem;
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: lowercase;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .titlebar-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--window-title-text);
    opacity: 0.72;
  }

  .home-titlebar-label {
    margin-left: 0.35rem;
    opacity: 0.9;
  }

  .home-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .greeting {
    font-size: 1.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--text-color);
  }

  .icon-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    justify-items: center;
  }

  .windows-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 20;
  }

  .lain-video {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
  }

  .footer {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 1rem;
    display: flex;
    justify-content: center;
    z-index: 10;
  }

  .copyright {
    font-size: 0.875rem;
    color: var(--text-color);
    opacity: 0.8;
  }

  .konami-hint {
    position: absolute;
    bottom: 2.75rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.7rem;
    font-family: var(--font-display);
    color: var(--text-color);
    opacity: 0.4;
    z-index: 5;
  }

  .konami-controller {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1000;
    width: min(92vw, 520px);
    color: #69435b;
    isolation: isolate;
  }

  .konami-controller::before {
    content: '';
    position: fixed;
    inset: -100vmax;
    background: rgba(254, 240, 245, 0.68);
    z-index: -1;
  }

  .konami-controller.hidden {
    display: none;
  }

  .controller-shell {
    position: relative;
    padding: 1.25rem 1.35rem 1.45rem;
    border: 3px solid #d498a3;
    border-radius: 42px 42px 56px 56px;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 245, 247, 0.92) 0 12%, transparent 28%),
      radial-gradient(circle at 82% 20%, rgba(248, 211, 226, 0.82) 0 12%, transparent 30%),
      linear-gradient(145deg, #fff5f7 0%, #f8d3e2 54%, #e9b8c8 100%);
    box-shadow:
      0 24px 48px rgba(139, 69, 99, 0.22),
      inset 0 2px 0 rgba(255, 255, 255, 0.8),
      inset 0 -8px 18px rgba(139, 69, 99, 0.12);
  }

  .controller-shell::before,
  .controller-shell::after {
    content: '';
    position: absolute;
    bottom: -15px;
    width: 154px;
    height: 102px;
    border: 3px solid #d498a3;
    border-top: 0;
    border-radius: 0 0 64px 64px;
    background: linear-gradient(180deg, #f4c2d1 0%, #d498a3 100%);
    z-index: -1;
    box-shadow: inset 0 -8px 14px rgba(139, 69, 99, 0.12);
  }

  .controller-shell::before {
    left: 6px;
    transform: rotate(10deg);
  }

  .controller-shell::after {
    right: 6px;
    transform: rotate(-10deg);
  }

  .controller-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.85rem;
    padding: 0.25rem 0.35rem 0;
  }

  .controller-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .controller-mark {
    display: grid;
    place-items: center;
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 50%;
    background: #8b4563;
    color: #fff5f7;
    font-size: 0.9rem;
    box-shadow: inset 0 -2px 0 rgba(0, 0, 0, 0.18);
  }

  .controller-header h3 {
    color: #8b4563;
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0;
    margin: 0;
  }

  .controller-header button {
    width: 2.15rem;
    height: 2.15rem;
    display: grid;
    place-items: center;
    background: #fff5f7;
    border: 2px solid #d498a3;
    border-radius: 50%;
    color: #8b4563;
    font-size: 1.25rem;
    font-weight: 800;
    cursor: pointer;
    padding: 0;
    box-shadow: 0 3px 0 #c3829e;
    transition: transform 0.18s var(--ease-bubble), box-shadow 0.18s ease;
  }

  .controller-header button:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 0 #c3829e;
  }

  .controller-header button:active {
    transform: translateY(2px);
    box-shadow: 0 1px 0 #c3829e;
  }

  .sequence-progress {
    display: flex;
    justify-content: center;
    gap: 0.4rem;
    margin: 0 auto 1.2rem;
    padding: 0.4rem 0.55rem;
    width: max-content;
    border-radius: 9999px;
    background: rgba(139, 69, 99, 0.13);
    box-shadow: inset 0 2px 6px rgba(139, 69, 99, 0.12);
  }

  .sequence-progress .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #fff5f7;
    border: 2px solid #c3829e;
    box-shadow: inset 0 -1px 0 rgba(139, 69, 99, 0.16);
    transition: background-color 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .sequence-progress .dot.active {
    background: #ffb7ce;
    border-color: #8b4563;
    box-shadow: 0 0 12px rgba(242, 185, 196, 0.88), inset 0 -1px 0 rgba(139, 69, 99, 0.18);
  }

  .controller-body jpad-controller {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.1rem;
    height: 154px !important;
    min-height: 0 !important;
  }

  .dpad {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 0;
    width: 126px;
    height: 126px;
    place-items: center;
    border-radius: 50%;
    background: #e5a8b7;
    box-shadow:
      inset 0 4px 9px rgba(255, 245, 247, 0.62),
      inset 0 -7px 12px rgba(139, 69, 99, 0.16);
  }

  .dpad::before {
    content: '';
    grid-column: 2;
    grid-row: 2;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #323044;
    box-shadow: inset 0 2px 0 rgba(255, 255, 255, 0.12);
    z-index: 1;
  }

  .dpad jpad-button {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: #343247;
    border: 0;
    color: #fff5f7;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 800;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 4px 0 #1f1e2d,
      inset 0 2px 0 rgba(255, 255, 255, 0.12);
    transition: transform 0.14s var(--ease-bubble), box-shadow 0.14s ease, background-color 0.14s ease;
    z-index: 2;
  }

  .dpad jpad-button:hover {
    background: #47445f;
    transform: translateY(-1px);
  }

  .dpad jpad-button:active {
    transform: translateY(3px);
    box-shadow:
      0 1px 0 #1f1e2d,
      inset 0 2px 4px rgba(0, 0, 0, 0.22);
  }

  .dpad jpad-button:nth-child(1) { grid-column: 2; grid-row: 1; }
  .dpad jpad-button:nth-child(2) { grid-column: 2; grid-row: 3; }
  .dpad jpad-button:nth-child(3) { grid-column: 1; grid-row: 2; }
  .dpad jpad-button:nth-child(4) { grid-column: 3; grid-row: 2; }

  .controller-center {
    display: grid;
    justify-items: center;
    gap: 0.35rem;
    min-width: 76px;
    padding-top: 0.2rem;
  }

  .speaker-line {
    width: 48px;
    height: 5px;
    border-radius: 9999px;
    background: rgba(139, 69, 99, 0.38);
    box-shadow: inset 0 1px 0 rgba(255, 245, 247, 0.5);
  }

  .start-pill {
    margin-top: 0.4rem;
    padding: 0.25rem 0.7rem;
    border-radius: 9999px;
    background: #8b4563;
    color: #fff5f7;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: lowercase;
    box-shadow: inset 0 -2px 0 rgba(0, 0, 0, 0.18);
  }

  .action-buttons {
    display: flex;
    justify-content: center;
    gap: 0.95rem;
    padding: 1.05rem;
    border-radius: 9999px;
    background: #e5a8b7;
    transform: rotate(-14deg);
    box-shadow:
      inset 0 4px 9px rgba(255, 245, 247, 0.62),
      inset 0 -7px 12px rgba(139, 69, 99, 0.16);
  }

  .action-buttons jpad-button {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    border: 0;
    color: #fff5f7;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 800;
    cursor: pointer;
    transform: rotate(14deg);
    transition: transform 0.14s var(--ease-bubble), box-shadow 0.14s ease, filter 0.14s ease;
  }

  .action-buttons jpad-button#btn-b {
    background: #8b4563;
    box-shadow:
      0 5px 0 #5b263f,
      inset 0 2px 0 rgba(255, 245, 247, 0.28);
  }

  .action-buttons jpad-button#btn-a {
