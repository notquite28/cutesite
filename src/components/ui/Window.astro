---
export interface Props {
  id: string
  title: string
  width?: string
  height?: string
}

const { id, title, width, height } = Astro.props

const widthStyle = width || 'min(90vw, 650px)'
const heightStyle = height || 'auto'
---

<div
  class="window"
  data-window-id={id}
  style={`width: ${widthStyle}; ${height !== 'auto' ? `height: ${heightStyle};` : ''}`}
>
  <header class="window-header" data-drag-handle>
    <div class="window-titlebar-dots">
      <button class="titlebar-dot titlebar-dot-close" data-close aria-label={`Close ${title}`}></button>
      <span class="titlebar-dot titlebar-dot-minimize"></span>
      <span class="titlebar-dot titlebar-dot-maximize"></span>
    </div>
    <span class="window-title">{title}</span>
  </header>
  <main class="window-content">
    <slot />
  </main>
</div>

<style>
  .window {
    position: absolute;
    border-radius: 14px;
    box-shadow: var(--window-shadow);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--window-border);
    background-color: var(--window-content-bg);
    backdrop-filter: blur(var(--window-blur)) saturate(var(--window-saturate));
    -webkit-backdrop-filter: blur(var(--window-blur)) saturate(var(--window-saturate));
    opacity: 0;
    transform: scale(0.9);
    max-width: calc(100vw - 24px);
    max-height: calc(100vh - 24px);
    transition: opacity 0.3s var(--ease-bubble), transform 0.3s var(--ease-bubble);
  }

  .window.is-open {
    opacity: 1;
    transform: scale(1);
  }

  .window.is-active {
    box-shadow: var(--window-shadow), 0 0 0 1px rgba(255, 255, 255, 0.2), 0 0 20px rgba(147, 112, 219, 0.2);
  }

  .window.is-dragging {
    opacity: 0.95;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(255, 255, 255, 0.15);
    transition: none;
  }

  .window-header {
    background-color: var(--window-title-bg);
    backdrop-filter: blur(var(--window-blur)) saturate(var(--window-saturate));
    -webkit-backdrop-filter: blur(var(--window-blur)) saturate(var(--window-saturate));
    color: var(--window-title-text);
    padding: 0.5rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: move;
    user-select: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .window-title {
    font-weight: bold;
    font-size: 0.875rem;
    text-transform: lowercase;
  }

  .window-content {
    padding: 1.5rem;
    overflow: auto;
    flex: 1;
    background-color: transparent;
  }

  .window.is-loading .window-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 150px;
  }

  @media (max-width: 640px) {
    .window {
      min-width: 280px !important;
      max-width: 95% !important;
    }
  }
</style>
